# Backend-only compose example. For the full app, prefer ../docker-compose.yml
# with ../.env.production.example copied to ../.env.
APP_ENV_FILE=.env

POSTGRES_USER=livecode_user
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_DB=livecode_db
DATABASE_URL=postgresql+asyncpg://livecode_user:replace-with-url-encoded-password@db:5432/livecode_db
REDIS_URL=redis://redis:6379/0
BACKEND_PORT=8001

SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
BACKEND_CORS_ORIGINS=https://livecodetechnologies.com,https://admin.livecodetechnologies.com
PUBLIC_SITE_URL=https://livecodetechnologies.com
API_PUBLIC_URL=https://api.livecodetechnologies.com

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@livecodetechnologies.com
EMAILS_FROM_NAME=Livecode Technologies
COMPANY_NOTIFICATION_EMAIL=

MPESA_ENVIRONMENT=live
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_CALLBACK_URL=https://api.livecodetechnologies.com/api/v1/payments/mpesa/callback
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_CALLBACK_URL=https://api.livecodetechnologies.com/api/v1/payments/paystack/callback
PAYSTACK_WEBHOOK_URL=https://api.livecodetechnologies.com/api/v1/payments/paystack/webhook
PAYSTACK_FRONTEND_RETURN_URL=https://livecodetechnologies.com
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

UPLOAD_ROOT=var/uploads
IMAGE_UPLOAD_MAX_BYTES=10485760
REQUIRE_MALWARE_SCANNER=false
S3_ENDPOINT=
S3_REGION=eu-central-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=livecode_files
S3_TRAINER_PREFIX=trainers
BLOB_STORE_ID=
BLOB_READ_WRITE_TOKEN=

RATE_LIMIT_PER_MINUTE=60
NEWSLETTER_WORKER_ENABLED=true
NEWSLETTER_WORKER_INTERVAL_SECONDS=300
NEWSLETTER_DIGEST_INTERVAL_DAYS=7
